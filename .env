# Redis URL (automatically handled by docker-compose)
REDIS_URL=redis://redis:6379

# AI API Keys (Optional - the system falls back to keyword extraction if neither is provided)
# Provide one of the following to enable intelligent NLP processing of distress messages and the Fleet Advisor:

# Option A: Google Gemini
GEMINI_API_KEY="ur api key "

# Option B: OpenAI (or compatible proxy)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/

# Mapbox GL JS public token
VITE_MAPBOX_TOKEN="your api key "
