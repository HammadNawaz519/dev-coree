# Redis URL (automatically handled by docker-compose)
REDIS_URL=redis://redis:6379

# ── AI / NLP (at least one recommended for full AI features) ──────────────────

# Option A: OpenRouter (recommended — works for both distress NLP and Fleet Advisor)
# Supports 200+ models including Gemini, GPT-4o, Claude, Mistral via one key.
OPENROUTER_API_KEY="ur api key"

# Model to use via OpenRouter (free tier options shown)
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free


# Mapbox GL JS public token (required for the map)
VITE_MAPBOX_TOKEN="ur api key"
