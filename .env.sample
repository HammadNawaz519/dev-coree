# --- FRONTEND ---
# Groq API (Fleet Advisor AI)
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Mapbox GL JS public token
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Backend (for local dev only)
REDIS_URL=redis://redis:6379

# --- BACKEND ---
# Redis URL (automatically handled by docker-compose)
REDIS_URL=redis://redis:6379

# ── AI / NLP ──────────────────────────────────────────────────────────
# Option A: OpenRouter (recommended — works for both distress NLP and Fleet Advisor)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Mapbox GL JS public token (required for the map)
VITE_MAPBOX_TOKEN=your_mapbox_token_here
